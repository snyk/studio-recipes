    "mcp-config": {
      "type": "mcp",
      "description": "Snyk MCP server configuration",
      "enabled": true,
      "sources": {
        "cursor": {
          "config_merge": {
            "target": ".cursor/.mcp.json",
            "source": "mcp/.mcp.json",
            "strategy": "merge_mcp_servers"
          }
        },
        "claude": {
          "config_merge": {
            "target": ".claude/.mcp.json",
            "source": "mcp/.mcp.json",
            "strategy": "merge_mcp_servers"
          }
        },
        "gemini": {
          "config_merge": {
            "target": ".gemini/settings.json",
            "source": "mcp/.mcp.json",
            "strategy": "merge_mcp_servers"
          }
        },
        "kiro": {
          "config_merge": {
            "target": ".kiro/settings/mcp.json",
            "source": "mcp/.mcp.json",
            "strategy": "merge_mcp_servers"
          }
        },
        "windsurf": {
          "config_merge": {
            "target": ".codeium/windsurf/mcp_config.json",
            "source": "mcp/.mcp.json",
            "strategy": "merge_mcp_servers"
          }
        }
      }
    },
