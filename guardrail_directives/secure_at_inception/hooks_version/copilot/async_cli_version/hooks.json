{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "bash": "uv run \"$HOME/.copilot/hooks/snyk_secure_at_inception.py\"",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "uv run \"$HOME/.copilot/hooks/snyk_secure_at_inception.py\"",
        "timeoutSec": 30
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "uv run \"$HOME/.copilot/hooks/snyk_secure_at_inception.py\"",
        "timeoutSec": 5
      }
    ]
  }
}
