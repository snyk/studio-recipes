{
  "version": "1.0.0",
  "description": "Snyk Studio Recipes - Default Distribution",
  "prerequisites": {
    "python": "3.8"
  },
  "recipes": {
    "sai-hooks-async": {
      "type": "hooks",
      "description": "Secure At Inception hooks (async CLI version)",
      "enabled": true,
      "sources": {
        "cursor": {
          "files": [
            { "src": "guardrail_directives/secure_at_inception/hooks_version/cursor/async_cli_version/snyk_secure_at_inception.py", "dest": ".cursor/hooks/snyk_secure_at_inception.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/cursor/async_cli_version/lib/platform_utils.py", "dest": ".cursor/hooks/lib/platform_utils.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/cursor/async_cli_version/lib/scan_runner.py", "dest": ".cursor/hooks/lib/scan_runner.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/cursor/async_cli_version/lib/scan_worker.py", "dest": ".cursor/hooks/lib/scan_worker.py" }
          ],
          "config_merge": {
            "target": ".cursor/hooks.json",
            "source": "guardrail_directives/secure_at_inception/hooks_version/cursor/async_cli_version/hooks.json",
            "strategy": "merge_cursor_hooks"
          }
        },
        "claude": {
          "files": [
            { "src": "guardrail_directives/secure_at_inception/hooks_version/claude/async_cli_version/snyk_secure_at_inception.py", "dest": ".claude/hooks/snyk_secure_at_inception.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/claude/async_cli_version/lib/platform_utils.py", "dest": ".claude/hooks/lib/platform_utils.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/claude/async_cli_version/lib/scan_runner.py", "dest": ".claude/hooks/lib/scan_runner.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/claude/async_cli_version/lib/scan_worker.py", "dest": ".claude/hooks/lib/scan_worker.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/claude/async_cli_version/lib/sca_scan_worker.py", "dest": ".claude/hooks/lib/sca_scan_worker.py" }
          ],
          "config_merge": {
            "target": ".claude/settings.json",
            "source": "guardrail_directives/secure_at_inception/hooks_version/claude/async_cli_version/settings.json",
            "strategy": "merge_claude_settings"
          }
        },
        "gemini": {
          "files": [
            { "src": "guardrail_directives/secure_at_inception/hooks_version/gemini/async_cli_version/snyk_secure_at_inception.py", "dest": ".gemini/hooks/snyk_secure_at_inception.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/gemini/async_cli_version/lib/platform_utils.py", "dest": ".gemini/hooks/lib/platform_utils.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/gemini/async_cli_version/lib/scan_runner.py", "dest": ".gemini/hooks/lib/scan_runner.py" },
            { "src": "guardrail_directives/secure_at_inception/hooks_version/gemini/async_cli_version/lib/scan_worker.py", "dest": ".gemini/hooks/lib/scan_worker.py" }
          ],
          "config_merge": {
            "target": ".gemini/settings.json",
            "source": "guardrail_directives/secure_at_inception/hooks_version/gemini/async_cli_version/settings.json",
            "strategy": "merge_gemini_settings"
          }
        }
      }
    },
