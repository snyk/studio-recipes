{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "uv run \"$HOME/.cursor/hooks/snyk_secure_at_inception.py\"",
        "timeout": 600
      }
    ],
    "afterFileEdit": [
      {
        "command": "uv run \"$HOME/.cursor/hooks/snyk_secure_at_inception.py\"",
        "timeout": 600
      }
    ],
    "stop": [
      {
        "command": "uv run \"$HOME/.cursor/hooks/snyk_secure_at_inception.py\"",
        "timeout": 600
      }
    ]
  }
}
