# =============================================================================

def get_sast_with_cache(
    staged: StagedChanges,
    cache: SnykCache
) -> Tuple[SastScanResult, int, int]:
    """
    Get SAST results using cache where available.
    
    Returns:
        Tuple of (SastScanResult, cache_hits, cache_misses)
    """
    all_vulns: List[CodeVulnerability] = []
    cache_hits = 0
    cache_misses = 0
    uncached_files: List[str] = []
    
    print_info("Checking SAST cache...")
    
    for file_path in staged.changed_code_files:
        # DEBUG: Log cache lookup details
        file_hash = cache.compute_file_hash(file_path)
        if DEBUG:
            print(f"  DEBUG: Looking up cache for {file_path}, hash={file_hash}")
        cached = cache.get_sast_result(file_path)
        if DEBUG:
            print(f"  DEBUG: Cache result: {cached is not None}, NO_CACHE={NO_CACHE}")
        
        if cached and not NO_CACHE:
            cache_hits += 1
            print_cache_status(True, Path(file_path).name)
            
            # Convert cached vulns back to CodeVulnerability objects
            for v in cached.vulnerabilities:
                all_vulns.append(CodeVulnerability(
                    id=v.get("id", "unknown"),
                    title=v.get("title", "Unknown"),
                    severity=v.get("severity", "medium"),
                    cwe=v.get("cwe"),
                    file_path=file_path,
                    start_line=v.get("start_line", 0),
                    end_line=v.get("end_line", 0),
                    message=v.get("message", "")
                ))
        else:
            cache_misses += 1
            uncached_files.append(file_path)
            print_cache_status(False, Path(file_path).name)
    
    # Run fresh scans for uncached files
    if uncached_files:
        print_info(f"Running SAST scan on {len(uncached_files)} uncached file(s)...")
        
        # Run scan on entire project (Snyk Code works better this way)
        fresh_result = run_sast_scan(".")
        
        if fresh_result.success:
            # Filter to only uncached files and add to results
            for v in fresh_result.vulnerabilities:
                # Check if this vuln is in an uncached file
                for uncached in uncached_files:
                    if (v.file_path == uncached or 
                        v.file_path.endswith(uncached) or 
                        uncached.endswith(v.file_path) or
                        Path(v.file_path).name == Path(uncached).name):
                        all_vulns.append(v)
                        break
            
            # Cache the results for these files
            for file_path in uncached_files:
                file_vulns = [
                    {
                        "id": v.id,
                        "title": v.title,
                        "severity": v.severity,
                        "cwe": v.cwe,
                        "start_line": v.start_line,
                        "end_line": v.end_line,
                        "message": v.message
                    }
                    for v in fresh_result.vulnerabilities
                    if (v.file_path == file_path or 
                        v.file_path.endswith(file_path) or
                        file_path.endswith(v.file_path) or
                        Path(v.file_path).name == Path(file_path).name)
                ]
                cache.set_sast_result(file_path, file_vulns)
        else:
            print_warning(f"SAST scan failed: {fresh_result.error_message}")
    
    return SastScanResult(success=True, vulnerabilities=all_vulns), cache_hits, cache_misses


def resolve_installed_version(package_name: str, semver_range: str) -> str:
    """
    Resolve the actual installed version from package-lock.json.
    Falls back to the semver range if resolution fails.
    """
    import json
    
    try:
        # Try to read package-lock.json
        lock_file = Path("package-lock.json")
        if not lock_file.exists():
            return semver_range.lstrip('^~>=<')
        
        with open(lock_file, 'r') as f:
            lock_data = json.load(f)
        
        # Check in packages (lockfileVersion 2+)
        if "packages" in lock_data:
            pkg_key = f"node_modules/{package_name}"
            if pkg_key in lock_data["packages"]:
                return lock_data["packages"][pkg_key].get("version", semver_range.lstrip('^~>=<'))
        
        # Check in dependencies (lockfileVersion 1)
        if "dependencies" in lock_data and package_name in lock_data["dependencies"]:
            return lock_data["dependencies"][package_name].get("version", semver_range.lstrip('^~>=<'))
        
    except Exception:
        pass  # Fall back to semver range
    
    return semver_range.lstrip('^~>=<')


def get_sca_with_cache(
    staged: StagedChanges,
    cache: SnykCache
) -> Tuple[ScaScanResult, int, int]:
    """
    Get SCA results using cache where available.
    
    Returns:
        Tuple of (ScaScanResult, cache_hits, cache_misses)
    """
    all_vulns: List[DependencyVulnerability] = []
    cache_hits = 0
    cache_misses = 0
    need_fresh_scan = False
    
    print_info("Checking SCA cache...")
    
    for pkg_name, pkg_change in staged.packages.items():
        if pkg_change.new_version is None:
            continue  # Skip removed packages
        
        # Resolve actual installed version from package-lock.json
        version = resolve_installed_version(pkg_name, pkg_change.new_version)
        cached = cache.get_sca_result(pkg_name, version)
        
        if cached and not NO_CACHE:
            cache_hits += 1
            print_cache_status(True, f"{pkg_name}@{version}")
            
            # Convert cached vulns back to DependencyVulnerability objects
            # The cache now includes the full dependency tree
            for v in cached.vulnerabilities:
                all_vulns.append(DependencyVulnerability(
                    id=v.get("id", "unknown"),
                    title=v.get("title", "Unknown"),
                    severity=v.get("severity", "medium"),
                    package_name=v.get("package_name", pkg_name),
                    installed_version=v.get("installed_version", version),
                    fixed_version=v.get("fixed_version"),
                    cve=v.get("cve"),
                    cvss_score=None,
                    is_direct=v.get("package_name") == pkg_name,
                    dependency_path=v.get("dependency_path", [])
                ))
        else:
            cache_misses += 1
            need_fresh_scan = True
            print_cache_status(False, f"{pkg_name}@{version}")
    
    # Run fresh scan if any packages are uncached
    if need_fresh_scan:
        print_info("Running SCA scan on dependencies...")
        fresh_result = run_sca_scan(".")
        
        if fresh_result.success:
            # Add fresh results (avoiding duplicates from cache)
            cached_ids = {v.id for v in all_vulns}
            
            for v in fresh_result.vulnerabilities:
                if v.id not in cached_ids:
                    all_vulns.append(v)
            
            # Cache results per TOP-LEVEL package with their full dependency trees
            # Group vulnerabilities by the first package in the dependency path (the top-level package)
            packages_cached: Dict[str, Dict] = {}
            
            for v in fresh_result.vulnerabilities:
                # Find the top-level package (first package after project name in dependency path)
                if len(v.dependency_path) >= 2:
                    # dependency_path looks like: ['snyk-test-repo@1.0.0', 'express@4.14.1', ...]
                    top_level = v.dependency_path[1]  # e.g., 'express@4.14.1'
                    
                    # Extract package name and version
                    if '@' in top_level:
                        parts = top_level.rsplit('@', 1)
                        if len(parts) == 2:
                            top_pkg_name, top_pkg_version = parts
                            key = f"{top_pkg_name}@{top_pkg_version}"
                            
                            if key not in packages_cached:
                                packages_cached[key] = {
                                    "package": top_pkg_name,
                                    "version": top_pkg_version,
                                    "vulnerabilities": []
                                }
                            
                            packages_cached[key]["vulnerabilities"].append({
                                "id": v.id,
                                "title": v.title,
                                "severity": v.severity,
                                "fixed_version": v.fixed_version,
                                "cve": v.cve,
                                "package_name": v.package_name,
                                "installed_version": v.installed_version,
                                "dependency_path": v.dependency_path
                            })
            
            # Cache each top-level package with its full tree
            if DEBUG:
                print(f"Caching {len(packages_cached)} top-level packages")
                for key in packages_cached:
                    print(f"  {key}: {len(packages_cached[key]['vulnerabilities'])} vulnerabilities")
            
            for key, data in packages_cached.items():
                cache.set_sca_result(data["package"], data["version"], data["vulnerabilities"])
        else:
            print_warning(f"SCA scan failed: {fresh_result.error_message}")
    
    return ScaScanResult(success=True, vulnerabilities=all_vulns), cache_hits, cache_misses


# =============================================================================
# MAIN HOOK LOGIC
# =============================================================================

def run_hook() -> int:
    """
    Main hook execution.
    
    Returns:
        0 if commit should proceed
        1 if commit should be blocked
    """
    start_time = time.time()
    
    print_header("SNYK SECURITY PRE-COMMIT HOOK")
    
    # Initialize cache (uses temp directory with workspace hash)
    workspace = os.getcwd()
    workspace_abs = os.path.abspath(workspace)
    cache_dir = get_cache_dir(workspace)
    cache = SnykCache(cache_dir=cache_dir)
    
    if DEBUG:
        print(f"  Workspace (cwd): {workspace}")
        print(f"  Workspace (abs): {workspace_abs}")
        print(f"  Cache: {cache_dir}")
    
    # Step 1: Analyze staged changes
    print_info("Analyzing staged changes...")
    staged = get_staged_changes()
    
    if not staged.files and not staged.packages:
        print_success("No significant changes to scan")
        return 0
    
    if DEBUG:
        print(f"  Code files: {len(staged.changed_code_files)}")
        print(f"  Packages: {len(staged.packages)}")
    
    # Step 2: Get scan results (cache-aware)
    sast_result: Optional[SastScanResult] = None
    sca_result: Optional[ScaScanResult] = None
    total_cache_hits = 0
    total_cache_misses = 0
    
    if staged.has_code_changes:
        sast_result, hits, misses = get_sast_with_cache(staged, cache)
        total_cache_hits += hits
        total_cache_misses += misses
        
        if DEBUG and sast_result:
            print(f"  Found {len(sast_result.vulnerabilities)} total code vulnerabilities")
    
    if staged.has_package_changes:
        sca_result, hits, misses = get_sca_with_cache(staged, cache)
        total_cache_hits += hits
        total_cache_misses += misses
        
        if DEBUG and sca_result:
            print(f"  Found {len(sca_result.vulnerabilities)} total dependency vulnerabilities")
    
    # Show cache efficiency
    if total_cache_hits + total_cache_misses > 0:
        hit_rate = total_cache_hits / (total_cache_hits + total_cache_misses) * 100
        print_info(f"Cache: {total_cache_hits} hits, {total_cache_misses} misses ({hit_rate:.0f}% hit rate)")
    
    # Step 3: Filter to NEW vulnerabilities only
    print_info("Filtering to vulnerabilities introduced by this commit...")
    result = analyze_staged_changes(
        staged,
        sast_result,
        sca_result,
        quick_mode=QUICK_MODE
    )
    
    # Step 4: Report findings
    if result.new_code_vulns:
        print_header("NEW CODE VULNERABILITIES DETECTED")
        print(f"\n{len(result.new_code_vulns)} new vulnerabilit{'y' if len(result.new_code_vulns) == 1 else 'ies'} introduced by your changes:\n")
        print(format_code_vuln_table(result.new_code_vulns))
    
    if result.package_deltas:
        has_regressions = any(d.is_regression for d in result.package_deltas)
        
        if has_regressions:
            print_header("DEPENDENCY SECURITY REGRESSIONS")
            print(f"\nPackage changes with security impact:\n")
        else:
            print_info("\nPackage security status:")
        
        print(format_package_table(result.package_deltas))
    
    # Step 5: Decision
    elapsed = time.time() - start_time
    
    if result.should_block_commit:
        print_header("COMMIT BLOCKED")
        print_error(result.block_reason)
        print(generate_detailed_fix_instructions(result))
        print(colored(f"\n⏱  Completed in {elapsed:.1f}s", Colors.WHITE))
        return 1
    
    # All clear
    print_header("SECURITY CHECK PASSED")
    
    if result.existing_code_vulns:
        print_warning(f"Note: {len(result.existing_code_vulns)} existing code vulnerabilities were not introduced by this commit")
    
    print_success("No new security issues introduced. Commit proceeding.")
    print(colored(f"⏱  Completed in {elapsed:.1f}s", Colors.WHITE))
    return 0


# =============================================================================
# ENTRY POINT
# =============================================================================

if __name__ == "__main__":
    try:
        exit_code = run_hook()
        sys.exit(exit_code)
    except KeyboardInterrupt:
        print("\nHook interrupted")
        sys.exit(1)
    except Exception as e:
        print_error(f"Hook error: {e}")
        if DEBUG:
            import traceback
            traceback.print_exc()
        # Don't block commits on hook errors
        print_warning("Allowing commit due to hook error")
        sys.exit(0)
